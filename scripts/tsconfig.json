// scripts/tsconfig.json
{
  "extends": "../tsconfig.json", // Mewarisi konfigurasi dasar dari tsconfig.json utama
  "compilerOptions": {
    "outDir": "../scripts-build", // Lokasi output untuk file JavaScript yang dikompilasi
    "rootDir": ".",               // Direktori root untuk kompilasi ini adalah folder 'scripts'
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Node",  // Penting untuk Node.js ES Modules agar path relatif bekerja baik
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,             // Matikan checkJs untuk scripts jika tidak diperlukan
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false               // Pastikan ini false agar tsc menghasilkan file JS
  },
  "include": [
    "./downloadThumbnails.ts"     // Hanya sertakan skrip ini
  ],
  "exclude": ["node_modules", "../dist"]
}