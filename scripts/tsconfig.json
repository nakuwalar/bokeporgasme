// scripts/tsconfig.json
{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../scripts-build",
    "rootDir": "../",
    "module": "NodeNext", // <--- CHANGE to "NodeNext" for better modern Node.js ESM handling
    "target": "ESNext",
    "moduleResolution": "NodeNext", // <--- CHANGE to "NodeNext"
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false, // Keep this as false, because we want to emit JS
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true // Keep this true
    // NO NEED to add "emitDeclarationOnly": true here as we want actual JS files emitted
  },
  "include": [
    "./downloadThumbnails.ts"
  ],
  "exclude": ["node_modules"]
}