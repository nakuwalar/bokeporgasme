---
import type { AstroBuiltinAttributes } from 'astro';

interface Props {
  title: string;
  description: string;
  image?: string; // URL gambar untuk Open Graph & Twitter Cards
  url?: string;   // Canonical URL
  schema?: Record<string, any>; // Prop untuk data Schema JSON-LD
  prevPage?: string; // URL halaman sebelumnya untuk pagination
  nextPage?: string; // URL halaman berikutnya untuk pagination
}

const { title, description, image, url, schema, prevPage, nextPage } = Astro.props;
const siteUrl = Astro.site?.toString() || "https://www.example.com/"; // Menggunakan Astro.site untuk URL dasar

// Pastikan URL gambar adalah absolute untuk Open Graph/Twitter Cards
// Jika gambar sudah dari public/, Astro.site akan membantu menjadikannya absolut
const absoluteImageUrl = image ? new URL(image, siteUrl).href : `${siteUrl}images/default-og-image.jpg`;
const canonicalUrl = url || Astro.url.href;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* Menggunakan font Inter */
    html {
      font-family: 'Inter', sans-serif;
    }
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

    /* Aspect Ratio untuk video embed (untuk responsivitas iframe) */
    .aspect-w-16 {
      position: relative;
      padding-bottom: 56.25%; /* 16:9 aspect ratio */
      height: 0;
      overflow: hidden; /* Pastikan tidak ada overflow di luar container */
    }
    .aspect-w-16 iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
  </style>

  <!-- Dasar SEO: Title & Description -->
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Canonical URL: Penting untuk menghindari duplikasi konten -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- rel="prev" dan rel="next" untuk pagination -->
  {prevPage && <link rel="prev" href={prevPage} />}
  {nextPage && <link rel="next" href={nextPage} />}

  <!-- Open Graph Meta Tags (untuk berbagi di media sosial) -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absoluteImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={schema?.['@type'] === 'Article' ? 'article' : schema?.['@type'] === 'Product' ? 'product' : schema?.['@type'] === 'VideoObject' ? 'video.other' : 'website'} />

  <!-- Twitter Card Meta Tags -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteImageUrl} />
  {/* <meta name="twitter:site" content="@yourtwitterhandle" /> <!-- Opsional --> */}

  <!-- JSON-LD Schema Markup -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body>
  <slot />
</body>
</html>
