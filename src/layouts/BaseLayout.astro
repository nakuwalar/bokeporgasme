---
import { nama, desk, url } from '../utils/site.ts';

export interface Props {
  title: string;
  description: string;
  preconnectDomains?: string[];
  siteName?: string;
  siteUrl?: string;
}

const {
  title,
  description,
  preconnectDomains = [],
  siteName = nama, // Using 'nama' from utils/site.ts
  siteUrl = url // Using 'url' from utils/site.ts
} = Astro.props;

// Ensure ogImageFullUrl is correctly formed from the base URL
const ogImageFullUrl = new URL('/og-image.jpg', url).href;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    {/* Meta Tags for SEO and Social Media */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {/* Use Astro.url.href for specific page URL */}
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageFullUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageFullUrl} />

    {preconnectDomains.map(domain => (
      <link rel="preconnect" href={domain} crossorigin>
    ))}

    <link rel="stylesheet" href="/global.css" />
  </head>
  <body>
    <header>
      <nav class="main-nav">
        <a href="/" class="logo">{siteName}</a>
        <form id="searchForm" action="/cari/" method="get" class="search-form"> {/* Add id="searchForm" */}
          <input type="search" name="query" placeholder="Cari video..." required />
          <button type="submit">Cari</button>
        </form>
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/category/">Category</a></li>
        </ul>
      </nav>
    </header>

    <slot />

    <footer>
      <p>&copy; {new Date().getFullYear()} <a href={siteUrl}>{siteName}</a>. All rights reserved.</p>
    </footer>

    {/* --- Crucial JavaScript for Clean Search URLs --- */}
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const searchForm = document.getElementById('searchForm');
        if (searchForm) {
          searchForm.addEventListener('submit', function(event) {
            event.preventDefault(); // Prevent default form submission (which uses ?query=keyword)

            const input = searchForm.querySelector('input[name="query"]');
            const query = input ? input.value.trim() : '';

            if (query) {
              // Simple slugify: replace spaces with hyphens, convert to lowercase
              const slugifiedQuery = query.toLowerCase().replace(/\s+/g, '-');
              // Redirect to the clean path-based URL
              window.location.href = `/cari/${slugifiedQuery}`; // This will be caught by /cari/[query]/index.astro
            } else {
              // If the search input is empty, you can redirect to a general search page or do nothing.
              // For now, redirect to /cari/ which will likely show no results if not handled.
              window.location.href = `/cari/`;
            }
          });
        }
      });
    </script>
  </body>
</html>
