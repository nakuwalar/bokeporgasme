---
// src/pages/cari/[query]/[page].astro
import Layout from '../../../layouts/BaseLayout.astro';
import VideoCard from '../../../components/VideoCard.astro';
import { getAllVideos, type VideoData } from '../../../utils/data';
import { slugify } from '../../../utils/slugify';
// import Paginasi from '../../../components/Paginasi.astro'; // Hapus import ini

// export async function getStaticPaths() { return []; } // Pertahankan ini untuk SSR on-demand, jangan prerender

const { query, page } = Astro.params;
const currentPage = page ? parseInt(page) : 1; // Ambil nomor halaman dari URL, default ke 1
const videosPerPage = 12; // Sesuaikan jumlah video per halaman

const originalQuery = query ? decodeURIComponent(query) : '';
const normalizedQuery = originalQuery.toLowerCase().trim().replace(/-/g, ' ');

console.log(`[CARI PAGE] Kueri asli dari URL: "${originalQuery}"`);
console.log(`[CARI PAGE] Kueri yang didekode & dinormalisasi: "${normalizedQuery}"`);
console.log(`[CARI PAGE] Halaman saat ini: ${currentPage}`);

let searchResults: VideoData[] = [];
let preconnectDomains: string[] = [];
let totalPages = 1;
let paginatedResults: VideoData[] = [];

try {
  const allVideos: VideoData[] = await getAllVideos();

  // Filter hasil pencarian
  searchResults = allVideos.filter(video =>
    video.title.toLowerCase().includes(normalizedQuery) ||
    video.description.toLowerCase().includes(normalizedQuery) ||
    video.category.toLowerCase().includes(normalizedQuery) ||
    (video.tags && video.tags.toLowerCase().includes(normalizedQuery))
  );

  // Urutkan hasil pencarian
  searchResults.sort((a, b) => a.title.localeCompare(b.title));

  // --- LOGIKA PAGINASI ---
  totalPages = Math.ceil(searchResults.length / videosPerPage);

  // Pastikan currentPage tidak kurang dari 1 dan tidak lebih dari totalPages
  const validCurrentPage = Math.max(1, Math.min(currentPage, totalPages));

  const startIndex = (validCurrentPage - 1) * videosPerPage;
  const endIndex = startIndex + videosPerPage;
  paginatedResults = searchResults.slice(startIndex, endIndex);

  console.log(`[CARI PAGE] Jumlah total hasil: ${searchResults.length}`);
  console.log(`[CARI PAGE] Total halaman: ${totalPages}`);
  console.log(`[CARI PAGE] Hasil paginasi di halaman ${validCurrentPage}: ${paginatedResults.length} video`);


  // Domain preconnect hanya untuk video di halaman yang sedang dilihat
  if (paginatedResults.length > 0) {
    const domainsSet = new Set<string>();
    paginatedResults.forEach(video => {
      try {
        domainsSet.add(new URL(video.thumbnail).origin);
        domainsSet.add(new URL(video.embedUrl).origin);
      } catch (e) {
        console.error(`[ERROR] URL tidak valid di JSON untuk video ID ${video.id} (pencarian paginasi):`, e);
      }
    });
    preconnectDomains = Array.from(domainsSet);
  }

} catch (error) {
  console.error('[CARI PAGE ERROR] Gagal melakukan pencarian:', error);
  searchResults = [];
  paginatedResults = []; // Pastikan ini juga kosong jika ada error
}

const breadcrumbs = [
  { name: 'Beranda', url: '/' },
  { name: `Cari: ${originalQuery}`, url: `/cari/${query}/1` }, // Link ke halaman 1 pencarian
  { name: `Halaman ${currentPage}`, url: `/cari/${query}/${currentPage}` },
];
---

<Layout
  title={`Hasil Pencarian untuk "${originalQuery}" - Halaman ${currentPage}`}
  description={`Video yang cocok dengan kata kunci: ${originalQuery}. Halaman ${currentPage}.`}
  preconnectDomains={preconnectDomains}
>
  <main class="search-page">
    <nav class="breadcrumb" aria-label="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <ol>
        {breadcrumbs.map((item, index) => (
          <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            {index > 0 && <span class="separator">/</span>}
            {item.url ? (
              <a itemprop="item" href={item.url}>
                <span itemprop="name">{item.name}</span>
              </a>
            ) : (
              <span itemprop="name">{item.name}</span>
            )}
            <meta itemprop="position" content={(index + 1).toString()} />
          </li>
        ))}
      </ol>
    </nav>

    <h1 class="search-results-title">{`Hasil Pencarian untuk: "${originalQuery}"`} <span class="page-info">(Halaman {currentPage} dari {totalPages})</span></h1>

    {paginatedResults.length === 0 ? (
      <p class="no-videos-found">
        Maaf, tidak ada video yang cocok dengan pencarian Anda. Coba kata kunci lain.
      </p>
    ) : (
      <div class="video-grid">
        {paginatedResults.map((video) => (
          <VideoCard video={video} videoDetailPath={`/${video.id}/${slugify(video.title)}`} />
        ))}
      </div>
    )}

    {/* --- Paginasi Langsung di Dalam Halaman --- */}
    {totalPages > 1 && (
      <nav class="pagination" aria-label="Navigasi Halaman Pencarian">
        {currentPage > 1 && (
          <a href={`/cari/${query}/${currentPage - 1}`} class="pagination-link">&laquo; Sebelumnya</a>
        )}
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(pageNumber => (
          <a
            href={`/cari/${query}/${pageNumber}`}
            class={`pagination-link ${pageNumber === currentPage ? 'active' : ''}`}
          >
            {pageNumber}
          </a>
        ))}
        {currentPage < totalPages && (
          <a href={`/cari/${query}/${currentPage + 1}`} class="pagination-link">Berikutnya &raquo;</a>
        )}
      </nav>
    )}
  </main>
</Layout>

<style>
  /* Tambahkan style ini ke file CSS global Anda (atau di sini, tapi global lebih baik) */
  .pagination {
    display: flex;
    justify-content: center;
    margin-top: 30px;
    margin-bottom: 30px;
    gap: 8px; /* Jarak antar link */
    flex-wrap: wrap; /* Pastikan responsif */
  }

  .pagination-link {
    display: block;
    padding: 10px 15px;
    border: 1px solid #ddd;
    border-radius: 5px;
    text-decoration: none;
    color: #007bff;
    background-color: #fff;
    transition: all 0.2s ease-in-out;
    min-width: 40px;
    text-align: center;
  }

  .pagination-link:hover:not(.active) {
    background-color: #e9ecef;
    border-color: #007bff;
  }

  .pagination-link.active {
    background-color: #007bff;
    color: white;
    border-color: #007bff;
    cursor: default; /* Tidak bisa diklik jika aktif */
  }

  .page-info {
    font-size: 0.8em;
    color: #666;
    margin-left: 10px;
  }
</style>
