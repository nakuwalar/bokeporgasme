---
import BaseLayout from '../layouts/BaseLayout.astro'; // Path disesuaikan: satu level ke atas
import videosData from '../videos.json'; // Path disesuaikan: satu level ke atas

// Fungsi getStaticPaths diperlukan untuk dynamic routes di Astro saat SSG
export async function getStaticPaths() {
  // Membuat jalur statis untuk setiap video menggunakan properti 'slug'
  // PERHATIKAN: Nama parameter di 'params' harus cocok dengan nama file [slug].astro
  return videosData.map((video) => ({
    params: { slug: video.slug }, // Menggunakan video.slug sebagai parameter untuk routing URL
    props: { video }, // Meneruskan seluruh objek video sebagai props
  }));
}

const { video } = Astro.props;

if (!video) {
  return Astro.redirect('/404'); // Redirect ke halaman 404 jika video tidak ditemukan
}

// Data Schema Markup untuk VideoObject
const videoSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": video.title,
  "description": video.description,
  "thumbnailUrl": new URL(video.thumbnail, Astro.site).href, // Pastikan URL absolut
  "uploadDate": "2025-06-19", // Ganti dengan tanggal upload video yang sebenarnya
  "embedUrl": video.embedUrl,
  // Anda bisa menambahkan properti lain seperti duration, transcript, publisher, dll.
};
---

<BaseLayout
  title={video.title}
  description={video.description}
  image={video.thumbnail}
  url={`${Astro.site}${video.slug}`} {/* PERHATIKAN: URL canonical tidak lagi memiliki '/video/' */}
  schema={videoSchema}
>
  <header class="bg-gray-900 text-white py-6 shadow-lg">
    <div class="container mx-auto px-4 md:px-8 flex items-center justify-between">
      <h1 class="text-2xl md:text-3xl font-extrabold">
        <a href="/" class="hover:text-gray-300 transition-colors">Klaten Video Hub</a>
      </h1>
      <a href="/" class="text-blue-300 hover:text-blue-100 transition-colors font-semibold flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Kembali ke Beranda
      </a>
    </div>
  </header>

  <main class="container mx-auto p-4 md:p-8">
    <h1 class="text-3xl md:text-4xl font-bold text-center text-gray-800 mb-6 rounded-lg p-4 bg-gradient-to-r from-teal-100 to-green-100 shadow-lg text-center">
      {video.title}
    </h1>

    <div class="aspect-w-16 aspect-h-9 bg-gray-200 rounded-lg overflow-hidden shadow-xl mb-6">
      <!-- Menggunakan iframe untuk embed video -->
      <iframe
        src={video.embedUrl}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        title={video.title}
        class="w-full h-full"
      ></iframe>
    </div>

    <div class="bg-white p-6 rounded-lg shadow-md mb-6">
      <h2 class="text-2xl font-semibold text-gray-700 mb-3 border-b pb-2">Deskripsi Video</h2>
      <p class="text-gray-700 leading-relaxed mb-4">{video.description}</p>

      <div class="flex flex-wrap gap-x-6 gap-y-2 text-gray-700 mb-3">
        <p class="font-medium text-lg">Kategori:</p>
        <span class="bg-purple-100 text-purple-800 text-lg font-semibold px-4 py-1.5 rounded-full shadow-sm">{video.category}</span>
      </div>

      <div class="flex flex-wrap gap-2 text-gray-700">
        <p class="font-medium text-lg">Tags:</p>
        {video.tags.map((tag) => (
          <span class="bg-gray-200 text-gray-700 text-md font-medium px-3.5 py-1.5 rounded-full hover:bg-gray-300 transition-colors cursor-pointer">#{tag}</span>
        ))}
      </div>
    </div>
  </main>

  <footer class="bg-gray-900 text-white py-8 mt-10 shadow-inner">
    <div class="container mx-auto px-4 md:px-8 text-center text-gray-400">
      <p>&copy; {new Date().getFullYear()} Klaten Video Hub. All rights reserved.</p>
      <p class="text-sm mt-2">Dibuat dengan ❤️ untuk Klaten.</p>
    </div>
  </footer>
</BaseLayout>
