---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import VideoCard from '../../../components/VideoCard.astro';
import Pagination from '../../../components/Pagination.astro'; // Impor komponen Paginasi
import videosData from '../../../../videos.json'; // Pastikan path ini sesuai

// Konfigurasi per halaman
const VIDEOS_PER_PAGE = 6; // Sesuaikan jumlah video per halaman

export async function getStaticPaths({ paginate }) {
  const allCategories = [...new Set(videosData.map(video => video.category))];

  let paginatedPaths = [];

  // Handle "all" category
  const sortedAllVideos = [...videosData].sort((a, b) => a.title.localeCompare(b.title)); // Urutkan semua video
  paginatedPaths = [
    ...paginatedPaths,
    ...paginate(sortedAllVideos, {
      params: { category: 'all' },
      pageSize: VIDEOS_PER_PAGE,
    }),
  ];

  // Handle individual categories
  for (const category of allCategories) {
    const slugifiedCategory = encodeURIComponent(category.toLowerCase().replace(/\s+/g, '-'));
    const filteredVideos = videosData.filter(video => video.category === category)
                                    .sort((a, b) => a.title.localeCompare(b.title)); // Urutkan per kategori

    paginatedPaths = [
      ...paginatedPaths,
      ...paginate(filteredVideos, {
        params: { category: slugifiedCategory },
        pageSize: VIDEOS_PER_PAGE,
      }),
    ];
  }

  return paginatedPaths;
}

const { page } = Astro.props;
const currentCategory = Astro.params.category; // Ambil slug kategori dari URL

// Dapatkan nama kategori yang sebenarnya (jika 'all' atau dari slug)
const displayCategoryName = currentCategory === 'all'
  ? 'Semua Video'
  : videosData.find(video => encodeURIComponent(video.category.toLowerCase().replace(/\s+/g, '-')) === currentCategory)?.category || currentCategory;

const pageTitle = currentCategory === 'all'
  ? `Semua Video Klaten - Halaman ${page.currentPage}`
  : `Video Kategori ${displayCategoryName} - Halaman ${page.currentPage}`;

const pageDescription = currentCategory === 'all'
  ? `Telusuri semua video menarik tentang Klaten, halaman ${page.currentPage}.`
  : `Temukan video-video pilihan dalam kategori ${displayCategoryName} dari Klaten, halaman ${page.currentPage}.`;

// Konstruksi URL canonical: selalu menunjuk ke halaman 1 kategori tersebut
const canonicalUrlBase = currentCategory === 'all'
  ? `${Astro.site}category/all/`
  : `${Astro.site}category/${currentCategory}/`;
const canonicalUrl = page.currentPage === 1 ? canonicalUrlBase : `${canonicalUrlBase}page/${page.currentPage}`;


---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  url={canonicalUrl}
  prevPage={page.url.prev}
  nextPage={page.url.next}
>
  <header class="bg-gray-900 text-white py-6 shadow-lg">
    <div class="container mx-auto px-4 md:px-8 flex items-center justify-between">
      <h1 class="text-2xl md:text-3xl font-extrabold">
        <a href="/" class="hover:text-gray-300 transition-colors">Klaten Video Hub</a>
      </h1>
      <a href="/" class="text-blue-300 hover:text-blue-100 transition-colors font-semibold flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Kembali ke Beranda
      </a>
    </div>
  </header>

  <main class="container mx-auto p-4 md:p-8">
    <h1 class="text-3xl md:text-4xl font-bold text-center text-gray-800 mb-8 rounded-lg p-4 bg-gradient-to-r from-yellow-100 to-orange-100 shadow-lg">
      Kategori: {displayCategoryName}
    </h1>

    <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      {page.data.map((video) => (
        <VideoCard video={video} />
      ))}
    </section>

    <!-- Komponen Paginasi -->
    <Pagination page={page} baseUrl={`/category/${currentCategory}`} />
  </main>

  <footer class="bg-gray-900 text-white py-8 mt-10 shadow-inner">
    <div class="container mx-auto px-4 md:px-8 text-center text-gray-400">
      <p>&copy; {new Date().getFullYear()} Klaten Video Hub. All rights reserved.</p>
      <p class="text-sm mt-2">Dibuat dengan ❤️ untuk Klaten.</p>
    </div>
  </footer>
</BaseLayout>
