---
// Perhatikan perubahan path ke components dan layouts
// Sekarang kita berada di src/pages/category/[category]/[page].astro
// Jadi, untuk keluar ke 'src/' kita perlu 3x '../'
import Layout from '../../../layouts/BaseLayout.astro';
import path from 'path';
import fs from 'fs';
import csv from 'csv-parser';
import VideoCard from '../../../components/VideoCard.astro';
import { slugify } from '../../../utils/slugify';

interface VideoData {
  id: string;
  title: string;
  description: string;
  thumbnail: string;
  duration: string;
  videoUrl: string;
  category: string;
}

// Definisikan VIDEOS_PER_PAGE di scope global frontmatter
const VIDEOS_PER_PAGE = 12; // Anda bisa sesuaikan jumlah video per halaman

export async function getStaticPaths() {
  const results: VideoData[] = [];
  const csvFilePath = path.resolve(process.cwd(), 'src/data/videos.csv');

  await new Promise<void>((resolve, reject) => {
    fs.createReadStream(csvFilePath)
      .pipe(csv({ separator: ';' }))
      .on('data', (data: VideoData) => results.push(data))
      .on('end', () => {
        resolve();
      })
      .on('error', (error) => {
        reject(error);
      });
  });

  const uniqueCategories = [...new Set(results.map((video) => video.category))];
  const paths: any[] = [];

  for (const category of uniqueCategories) {
    const sluggedCategory = slugify(category);
    const categoryVideos = results.filter((video) => slugify(video.category) === sluggedCategory);
    const totalPages = Math.ceil(categoryVideos.length / VIDEOS_PER_PAGE);

    // Pastikan selalu ada setidaknya satu halaman, bahkan jika tidak ada video
    const pagesToGenerate = totalPages === 0 ? 1 : totalPages;

    for (let page = 1; page <= pagesToGenerate; page++) {
      const startIndex = (page - 1) * VIDEOS_PER_PAGE;
      const endIndex = startIndex + VIDEOS_PER_PAGE;
      const paginatedVideos = categoryVideos.slice(startIndex, endIndex);

      paths.push({
        // params harus cocok dengan nama folder dinamis: [category] dan [page]
        params: { category: sluggedCategory, page: page.toString() },
        props: {
          categoryName: category, // Nama kategori asli
          videos: paginatedVideos,
          currentPage: page,
          totalPages: pagesToGenerate,
        },
      });
    }
  }
  return paths;
}

// Dapatkan parameter kategori dan halaman dari URL
const { category, page } = Astro.params;

// Dapatkan data kategori, video, dan informasi paginasi dari props
const { categoryName, videos, currentPage, totalPages } = Astro.props as {
  categoryName: string;
  videos: VideoData[];
  currentPage: number;
  totalPages: number;
};

// Fallback untuk memastikan actualCategoryName selalu ada
const actualCategoryName = categoryName || "Semua Kategori";
---

<Layout
  title={`Kategori: ${actualCategoryName} (Halaman ${currentPage}) | Video Portal`}
  description={`Kumpulan video dalam kategori ${actualCategoryName}, halaman ${currentPage}.`}
>
  <main class="category-page" itemscope itemtype="http://schema.org/CollectionPage">
    <meta itemprop="name" content={`Video Kategori: ${actualCategoryName}`} />
    <meta itemprop="description" content={`Kumpulan video dalam kategori ${actualCategoryName}, halaman ${currentPage}.`} />
    <meta itemprop="mainEntityOfPage" content={Astro.url.href} />

    {/* Breadcrumb untuk Halaman Kategori */}
    <nav class="breadcrumb" aria-label="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <ol>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <a itemprop="item" href="/">
            <span itemprop="name">Beranda</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <span class="separator">/</span>
          {/* Link ke halaman 1 kategori saat ini - HARUS /category/ */}
          <a itemprop="item" href={`/category/${category}/1`}>
            <span itemprop="name">{actualCategoryName}</span>
          </a>
          <meta itemprop="position" content="2" />
        </li>
        {totalPages > 1 && (
          <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            <span class="separator">/</span>
            <span itemprop="name">Halaman {currentPage}</span>
            <meta itemprop="position" content="3" />
          </li>
        )}
      </ol>
    </nav>

    <section class="category-header">
      <h1 itemprop="about" content={actualCategoryName}>Kategori: {actualCategoryName}</h1>
    </section>

    <section class="video-grid-section">
      <div class="video-grid" itemprop="hasPart" itemscope itemtype="http://schema.org/ItemList">
        {videos.length === 0 ? (
          <p class="no-videos">Tidak ada video dalam kategori ini.</p>
        ) : (
          videos.map((video, index) => (
            <div itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
              <meta itemprop="position" content={((currentPage - 1) * VIDEOS_PER_PAGE + index + 1).toString()} />
              <VideoCard video={video} />
            </div>
          ))
        )}
      </div>

      {/* Paginasi */}
      {totalPages > 1 && (
        <nav class="pagination" aria-label="Halaman Kategori">
          <ul>
            <li>
              <a
                href={currentPage > 1 ? `/category/${category}/${currentPage - 1}` : '#'}
                class={`page-link ${currentPage === 1 ? 'disabled' : ''}`}
                aria-disabled={currentPage === 1}
              >
                Sebelumnya
              </a>
            </li>
            {[...Array(totalPages)].map((_, i) => (
              <li>
                <a
                  href={`/category/${category}/${i + 1}`}
                  class={`page-link ${currentPage === i + 1 ? 'active' : ''}`}
                  aria-current={currentPage === i + 1 ? 'page' : undefined}
                >
                  {i + 1}
                </a>
              </li>
            ))}
            <li>
              <a
                href={currentPage < totalPages ? `/category/${category}/${currentPage + 1}` : '#'}
                class={`page-link ${currentPage === totalPages ? 'disabled' : ''}`}
                aria-disabled={currentPage === totalPages}
              >
                Berikutnya
              </a>
            </li>
          </ul>
        </nav>
      )}
    </section>
  </main>
</Layout>

<style>
  /* Gaya CSS untuk breadcrumb */
  .breadcrumb {
    margin-bottom: 20px;
    font-size: 0.9em;
    color: #666;
  }

  .breadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
  }

  .breadcrumb li {
    display: flex;
    align-items: center;
  }

  .breadcrumb a {
    color: var(--primary-color);
    text-decoration: none;
    white-space: nowrap;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb .separator {
    margin: 0 8px;
    color: #999;
  }

  /* Gaya CSS lainnya tidak berubah */
  .category-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
  }

  .category-header {
    text-align: center;
    margin-bottom: 30px;
  }

  .category-header h1 {
    font-size: clamp(2em, 4vw, 3em);
    color: #333;
  }

  .video-grid-section h2 {
    font-size: clamp(1.8em, 3.5vw, 2.2em);
    color: #333;
    margin-bottom: 25px;
    text-align: center;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 25px;
  }

  .no-videos {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 1.2em;
    color: #999;
    padding: 50px 0;
  }

  /* Gaya CSS untuk Paginasi */
  .pagination {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .pagination ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 10px;
    flex-wrap: wrap; /* Izinkan wrapping untuk layar kecil */
    justify-content: center;
  }

  .pagination li {
    display: inline-block;
  }

  .pagination .page-link {
    display: block;
    padding: 10px 15px;
    border: 1px solid #ddd;
    border-radius: 5px;
    text-decoration: none;
    color: var(--primary-color);
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .pagination .page-link:hover:not(.active):not(.disabled) {
    background-color: #f0f0f0;
  }

  .pagination .page-link.active {
    background-color: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
    cursor: default;
  }

  .pagination .page-link.disabled {
    color: #ccc;
    background-color: #f9f9f9;
    cursor: not-allowed;
  }

  /* Responsive Adjustments (tetap sama) */
  @media (max-width: 768px) {
    .video-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }
    .category-page {
      padding: 15px;
    }
    .pagination ul {
      gap: 8px; /* Kurangi gap pada layar kecil */
    }
    .pagination .page-link {
      padding: 8px 12px; /* Sesuaikan padding pada layar kecil */
    }
  }

  @media (max-width: 480px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
    .pagination ul {
      flex-direction: row; /* Pastikan tetap row untuk paginasi */
    }
  }
</style>
