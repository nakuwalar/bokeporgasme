---
// src/pages/category/[slug]/[page].astro
import Layout from '../../../layouts/BaseLayout.astro';
import VideoCard from '../../../components/VideoCard.astro';
import { getAllVideos, type VideoData } from '../../../utils/data'; // Import VideoData type
import { slugify } from '../../../utils/slugify';

export const prerender = true; // Penting untuk memastikan halaman ini di-prerender

export async function getStaticPaths() {
  const allVideos: VideoData[] = await getAllVideos(); // Gunakan type VideoData
  const videosPerPage = 30; // Sesuaikan jumlah video per halaman

  const paths = [];
  const categories: { [key: string]: VideoData[] } = {}; // Tentukan tipe untuk categories

  // Kelompokkan video berdasarkan kategori
  allVideos.forEach(video => {
    if (!categories[video.category]) {
      categories[video.category] = [];
    }
    categories[video.category].push(video);
  });

  // Buat path untuk setiap kategori dan setiap halaman paginasi
  for (const categoryName in categories) {
    const categorySlug = slugify(categoryName);
    const categoryVideos = categories[categoryName];
    const totalPages = Math.ceil(categoryVideos.length / videosPerPage);

    for (let i = 1; i <= totalPages; i++) {
      const startIndex = (i - 1) * videosPerPage;
      const endIndex = startIndex + videosPerPage;
      const paginatedVideosForPage = categoryVideos.slice(startIndex, endIndex);

      // Kumpulkan domain preconnect hanya untuk video di halaman ini
      const preconnectDomainsForPage = new Set<string>();
      paginatedVideosForPage.forEach(video => {
        try {
          // Tambahkan validasi jika URL mungkin kosong atau tidak valid
          if (video.thumbnail) {
            preconnectDomainsForPage.add(new URL(video.thumbnail).origin);
          }
          if (video.embedUrl) { // *** PERBAIKAN: Gunakan embedUrl ***
            preconnectDomainsForPage.add(new URL(video.embedUrl).origin);
          }
        } catch (e) {
          // Log error dengan ID video untuk memudahkan identifikasi
          // Pesan error dari Astro mungkin masih bilang CSV, tapi ini akan menunjukkan ID video JSON Anda
          console.error(`[ERROR] URL tidak valid untuk video ID "${video.id}" di kategori "${video.category}" (paginasi kategori):`, e);
          // Anda bisa memilih untuk tidak menambahkan domain ini atau mengabaikan video ini jika URL-nya kritis
        }
      });

      paths.push({
        params: {
          slug: categorySlug,
          page: i.toString(),
        },
        props: {
          categoryName,
          currentPage: i,
          totalPages,
          videos: paginatedVideosForPage, // *** PERBAIKAN: Hanya kirim video yang dipaginasi ***
          preconnectDomains: Array.from(preconnectDomainsForPage),
        },
      });
    }
  }
  return paths;
}

// *** PERBAIKAN: Hanya ambil 'videos' dari props, bukan 'categoryVideos' yang lengkap ***
const { categoryName, currentPage, totalPages, videos: paginatedVideos, preconnectDomains } = Astro.props;

// *** HAPUS: Ini tidak lagi diperlukan karena sudah difilter di getStaticPaths ***
// const videosPerPage = 12;
// const startIndex = (currentPage - 1) * videosPerPage;
// const endIndex = startIndex + videosPerPage;
// const paginatedVideos = categoryVideos.slice(startIndex, endIndex);

// Breadcrumb data
const breadcrumbs = [
  { name: 'Beranda', url: '/' },
  { name: 'Kategori', url: '/category/' },
  { name: categoryName, url: `/category/${slugify(categoryName)}/1` },
  { name: `Halaman ${currentPage}`, url: `/category/${slugify(categoryName)}/${currentPage}` },
];
---

<Layout
  title={`${categoryName} | Halaman ${currentPage} | BokepOrgasme`}
  description={`Kumpulan video kategori ${categoryName}, halaman ${currentPage}.`}
  preconnectDomains={preconnectDomains}
>
  <main class="category-page">
    <nav class="breadcrumb" aria-label="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <ol>
        {breadcrumbs.map((item, index) => (
          <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
            {index > 0 && <span class="separator">/</span>}
            {item.url ? (
              <a itemprop="item" href={item.url}>
                <span itemprop="name">{item.name}</span>
              </a>
            ) : (
              <span itemprop="name">{item.name}</span>
            )}
            <meta itemprop="position" content={(index + 1).toString()} />
          </li>
        ))}
      </ol>
    </nav>

    <h1 class="category-title-header">{categoryName} <span class="page-info">(Halaman {currentPage} dari {totalPages})</span></h1>

    {paginatedVideos.length === 0 ? (
      <p class="no-videos-in-category">Tidak ada video yang ditemukan dalam kategori ini.</p>
    ) : (
      <div class="video-grid">
        {paginatedVideos.map((video) => (
          <VideoCard video={video} />
        ))}
      </div>
    )}

    {totalPages > 1 && (
      <nav class="pagination" aria-label="Navigasi Halaman Kategori">
        {currentPage > 1 && (
          <a href={`/category/${slugify(categoryName)}/${currentPage - 1}`} class="pagination-link">&laquo; Sebelumnya</a>
        )}
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
          <a
            href={`/category/${slugify(categoryName)}/${page}`}
            class={`pagination-link ${page === currentPage ? 'active' : ''}`}
          >
            {page}
          </a>
        ))}
        {currentPage < totalPages && (
          <a href={`/category/${slugify(categoryName)}/${currentPage + 1}`} class="pagination-link">Berikutnya &raquo;</a>
        )}
      </nav>
    )}
  </main>
</Layout>
