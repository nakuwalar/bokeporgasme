---
interface Props {
  page: import('astro').Page;
  baseUrl: string; // Base URL untuk paginasi, misal '/category/kuliner' atau '/category/all'
}

const { page, baseUrl } = Astro.props;

// Fungsi helper untuk menghasilkan URL halaman
const getPageUrl = (pageNum: number) => {
  if (pageNum === 1) {
    return baseUrl; // Halaman 1 tidak memiliki /page/1
  }
  return `${baseUrl}/page/${pageNum}`;
};
---

<!-- Komponen navigasi paginasi. Hanya ditampilkan jika ada lebih dari 1 halaman. -->
{page.lastPage > 1 && (
  <nav class="flex justify-center items-center gap-2 mt-8 mb-4">
    <!-- Tautan ke halaman sebelumnya (rel="prev" untuk SEO) -->
    {page.url.prev && (
      <a
        href={page.url.prev}
        class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-300 transition-colors font-medium shadow-sm"
      >
        Sebelumnya
      </a>
    )}

    <!-- Menampilkan elipsis jika ada halaman yang dilewati di awal -->
    {page.currentPage > 2 && (
      <span class="text-gray-500 font-medium">...</span>
    )}

    <!-- Mengulang semua nomor halaman. Menampilkan hanya beberapa halaman di sekitar halaman saat ini. -->
    {page.allPages.map((pageNum) => (
      (pageNum === 1 || pageNum === page.lastPage || (pageNum >= page.currentPage - 1 && pageNum <= page.currentPage + 1)) && (
        <a
          href={getPageUrl(pageNum)}
          class:list={[
            "px-4 py-2 rounded-lg font-medium shadow-sm transition-colors",
            // Styling untuk halaman aktif
            { "bg-blue-600 text-white": page.currentPage === pageNum },
            // Styling untuk halaman tidak aktif
            { "bg-gray-200 text-gray-700 hover:bg-gray-300": page.currentPage !== pageNum }
          ]}
        >
          {pageNum}
        </a>
      )
    ))}

    <!-- Menampilkan elipsis jika ada halaman yang dilewati di akhir -->
    {page.currentPage < page.lastPage - 1 && (
      <span class="text-gray-500 font-medium">...</span>
    )}

    <!-- Tautan ke halaman berikutnya (rel="next" untuk SEO) -->
    {page.url.next && (
      <a
        href={page.url.next}
        class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-300 transition-colors font-medium shadow-sm"
      >
        Berikutnya
      </a>
    )}
  </nav>
)}
