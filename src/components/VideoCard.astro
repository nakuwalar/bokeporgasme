---
interface Props {
  video: {
    id: string; // Properti 'id' dari JSON asli (tetap ada, tidak berubah)
    slug: string; // Properti 'slug' yang dihasilkan dan DITAMBAHKAN oleh downloadThumbnails.js
    title: string;
    description: string;
    category: string;
    thumbnail: string;
    embedUrl: string;
    tags: string[];
  };
}

const { video } = Astro.props;
---
<article class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden border border-gray-200 flex flex-col">
  <!-- Tautan ke halaman detail video. Menggunakan 'video.slug' yang merupakan permalink SEO-friendly. -->
  <a href={`/video/${video.slug}`} class="block flex-shrink-0">
    <img
      src={video.thumbnail}
      alt={video.title}
      class="w-full h-48 object-cover object-center rounded-t-xl"
      loading="lazy"
    />
    <div class="p-4 flex-grow">
      <h2 class="text-xl font-semibold text-gray-800 mb-2 leading-tight">
        {video.title}
      </h2>
      <p class="text-gray-600 text-sm mb-3 line-clamp-3">
        {video.description}
      </p>
    </div>
  </a>
  <div class="px-4 pb-4 flex flex-wrap gap-2 mt-auto">
    <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-full">
      {video.category}
    </span>
    {video.tags.map((tag) => (
      <span class="bg-gray-100 text-gray-600 text-xs font-medium px-2.5 py-0.5 rounded-full">
        #{tag}
      </span>
    ))}
  </div>
</article>
