// scripts/tsconfig.json
{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../scripts-build", // <-- This means "one level up from 'scripts', then into 'scripts-build'"
    "rootDir": "../",             // <-- This means "the root of the project"
    "module": "NodeNext",
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,             // <-- MUST be false to generate JS
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "declaration": true
  },
  "include": [
    "./downloadThumbnails.ts" // <-- Make sure this correctly points to your script
  ],
  "exclude": ["node_modules"]
}
