{
  "extends": "astro/tsconfig/base",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@pages/*": ["src/pages/*"]
    },
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "src/**/*",
    "videos.json"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
